@model MesaAyudaCEIM5.Models.vista_participante

<script src="~/Scripts/jquery-3.4.1.js"></script>
<script src="~/Scripts/bootstrap.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
<script src="~/Scripts/Principal.js"></script>
<link href="~/Content/bootstrap.css" rel="stylesheet" />
<link href="~/Content/Estilos.css" rel="stylesheet" />


@{
    ViewBag.Title = "Principal";
}

@{
    string rutdv="";
    if (Model != null)
    {
        rutdv = Model.PersonaModel.rutdv;
    }
}
<div class="container-fluid">
    <div class="row">
        <div class="col-md-4">
            <h4>Hola, @Session["Nombres"].ToString()</h4>
        </div>
        <div class="col-md-8 text-right">
            <div class="btn-group" role="group" aria-label="...">
                @Html.ActionLink("Próximos Proyectos", "ProximosProyectos", "Proyectos", null, new { @class = "btn btn-primary btn-sm" })
            </div>
        </div>
    </div>
    <div class="row">
        <h1 class="page-header">Buscador</h1>
    </div>
    <div class="row">
        @using (Html.BeginForm("Principal", "Home"))
        {
            <p>
                RUT @Html.TextBox("id", @rutdv)
                <input type="submit" value="Buscar" />
            </p>
        }
    </div>

    @if (Model != null)
    {
        <div class="row">
            <div class="col-md-3 small">
                <h4>Detalle Participante</h4>
                <dl>
                    <dt>RUT</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.rutdv)</dd>
                    <dt>Paterno</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.paterno)</dd>
                    <dt>Materno</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.materno)</dd>
                    <dt>Nombres</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.nombres)</dd>
                    <dt>Género</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.genero)</dd>
                    <dt>Fecha Nacimiento</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.fecha_nacimiento)</dd>
                    <dt>Celular</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.celular)</dd>
                    <dt>Correo</dt>
                    <dd>@Html.DisplayFor(m => m.PersonaModel.correo)</dd>
                </dl>

            </div>

            <div class="col-md-9">
                <div class="tabs-left">
                    <ul class="nav nav-tabs">
                        <li class="active"><a href="#a" data-toggle="tab"><span class="glyphicon glyphicon-cog"></span></a></li>
                        <li><a href="#b" data-toggle="tab"><span class="glyphicon glyphicon-usd"></span></a></li>
                        <li><a href="#c" data-toggle="tab"><span class="glyphicon glyphicon-calendar"></span></a></li>
                        <li><a href="#d" data-toggle="tab"><span class="glyphicon glyphicon-time"></span></a></li>
                        <li><a href="#e" data-toggle="tab"><span class="glyphicon glyphicon-th-list"></span></a></li>
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane active" id="a">
                            <h4>LIstado de Proyectos</h4>
                            <table class="table small table-bordered table-hover">
                                <tr>
                                    <th align="center">N° Proyecto</th>
                                    <th align="center">Sede</th>
                                    <th align="center">Línea Negocio</th>
                                    <th align="center">Área</th>
                                    <th align="center">Estado</th>
                                    <th align="center">Curso</th>
                                    <th align="center">Inicio Ejecución</th>
                                    <th align="center">Fin Ejecución</th>
                                </tr>
                                @foreach (var item in Model.ProyectosParticipantesModel)
                                {
                                    <tr>
                                        <td>
                                            @{
                                                string pyp = item.pyp_id.ToString();
                                                string pry = item.pry_id.ToString();
                                            }
                                            @Html.ActionLink(pry, "Listado", "ProyectosParticipantes", new { pyp = pyp }, null)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nombre_sede_sigla)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nombre_linea_sigla)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nombre_area_sigla)
                                        </td>
                                        <td>

                                            <span class="label label-@Html.DisplayFor(modelItem => item.clase_label_estado_proyecto)">@Html.DisplayFor(modelItem => item.nombre_estado_proyecto)</span>
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nombre_proyecto)
                                            <br />
                                            <span class="label label-@Html.DisplayFor(modelItem => item.clase_label_modalidad)">@Html.DisplayFor(modelItem => item.modalidad_proyecto)</span>
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.inicio_ejecucion)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.termino_ejecucion)
                                        </td>
                                    </tr>
                                }
                            </table>
                        </div>
                        <div class="tab-pane" id="b">
                            <h4>Deuda Directa</h4>

                            <h4>Deuda Indirecta</h4>
                        </div>
                        <div class="tab-pane" id="c">
                            <h4>Programas</h4>
                        </div>
                        <div class="tab-pane" id="d">
                            <h4>Historial de Eventos</h4>
                            <table class="table small table-bordered table-hover">
                                <tr>
                                    <th align="center">Observacón</th>
                                    <th align="center">Fecha</th>
                                    <th align="center">Usuario</th>
                                </tr>
                                @foreach (var item in Model.ObservacionModel)
                                {
                                    <tr>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.observacion)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.fecha)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.nombre_usuario)
                                        </td>
                                    </tr>
                                }
                            </table>
                        </div>
                        <div class="tab-pane" id="e">
                            <h4>Etiquetas</h4>
                            <div class="panel-group" id="accordion" role="tablist" aria-multiselectable="true">
                                <div class="panel panel-default">
                                    @foreach (var item in Model.EtiquetaModel)
                                    {
                                        <div class="panel-heading" role="tab" id="headingOne">
                                            <h4 class="panel-title">
                                                <a role="button" data-toggle="collapse" data-parent="#accordion" href="#collapse@(item.eti_id)" aria-expanded="true" aria-controls="collapse@(item.eti_id)">
                                                    @Html.DisplayFor(modelItem => item.nombre_area) - @Html.DisplayFor(modelItem => item.nombre_etiqueta)
                                                </a>
                                            </h4>
                                        </div>
                                        <div id="collapse@(item.eti_id)" class="panel-collapse collapse" role="tabpanel" aria-labelledby="headingOne">
                                            <div class="panel-body">
                                                <table class="table table-bordered">
                                                    <tr>
                                                        <td>Descripción</td>
                                                        <td>Causa</td>
                                                        <td>Solución</td>
                                                    </tr>
                                                    <tr>
                                                        <td>@Html.DisplayFor(modelItem => item.descripcion)</td>
                                                        <td>@Html.DisplayFor(modelItem => item.causa)</td>
                                                        <td>@Html.DisplayFor(modelItem => item.solucion)</td>
                                                    </tr>
                                                </table>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

